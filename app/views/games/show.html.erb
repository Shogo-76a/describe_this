<div 
  data-controller="generated-image-polling"
  data-generated-image-polling-url-value="<%= check_generated_image_game_path(@game) %>"
  data-generated-image-polling-max-attempts-value="300"
  data-generated-image-polling-interval-value="2000"
  class="bg-base-300 min-h-full flex flex-col pt-0 z-10"
>
    <div data-controller="collapsible-image" class="bg-base-200 p-4 flex flex-col landscape:hero">
        <div data-collapsible-image-target="wrapperGlobal"        
            class="relative w-full aspect-[600/400] overflow-hidden 
                landscape:flex landscape:flex-row landscape:gap-4">

            <div data-collapsible-image-target="wrapperA"
                data-action="click->collapsible-image#toggle"
                class="absolute top-0 left-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                    landscape:h-auto">

                <div class="w-full h-full landscape:h-auto">
                    <img
                        id="theme-image-imgtag"
                        src="<%= @game.theme_image_url %>"
                        alt="お題イメージ"
                        class="w-full h-full landscape:h-auto object-cover object-left rounded-4xl">
                </div>
            </div>
            
            <div data-collapsible-image-target="wrapperB"
                data-action="click->collapsible-image#toggle"
                class="absolute top-0 right-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                    landscape:h-auto">

                <div id="generated-image" class="w-full h-full landscape:h-auto">
                    <div class="w-full h-full landscape:h-auto object-cover object-right aspect-[600/400] bg-base-100 rounded-4xl"></div>
                </div>
            </div>
        </div>
        
        <div id="scoring_button", class="flex justify-center m-5">
            <%=button_to "お題を 英語で 説明してください", "#", 
                method: :get, 
                class: "btn btn-lg bg-neutral/50 text-neutral-content/50 font-normal text-sm w-70 h-12 rounded-2xl", 
                disabled: true, 
                data: { collapsible_image_target: "submitButton"} %>
        </div>

        <!-- テキスト入力欄 -->
        <div class="max-w-2xl mx-auto w-full">
            <%= form_with(model: @game, 
                        data: { 
                            controller: "chat-form", 
                            chat_form_limit_value: 1, 
                            action: "
                                    submit->chat-form#validateForm 
                                    keydown->chat-form#handleKeydown 
                                    turbo:submit-end->chat-form#clear
                                    " 
                        }) do |f| %>

                <div class="flex gap-2 items-end">
                    <%= f.text_area :description, 
                        data: { chat_form_target: "textarea", 
                        action: "input->chat-form#resize"},
                        rows: 1,
                        class: "textarea textarea-bordered w-full resize-none py-2 min-h-[40px] h-[40px]", 
                        placeholder: "メッセージを入力..." %>

                    <%= f.button type: :submit, data: { chat_form_target: "submitButton" }, class: "btn btn-primary d-inline-flex align-items-center gap-2 rounded-full" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" style="width: 1.5rem; height: 1.5rem;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                    </svg>
                    <% end %>
                </div>
            <% end %>
        </div>
    </div>

    <!-- チャット欄 -->
    <div class="bg-base-300">
        <div class="w-full max-w-xl mx-auto px-4 py-5 flex flex-col gap-0">

                <div id="chat_messages_container">
                </div>
            
        </div>
    </div>
</div>
<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <!-- 空欄 -->
<% end %>
