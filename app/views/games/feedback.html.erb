<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <div class="flex items-end gap-0">
        <p class="text-2xl font-bold">フィードバック</p>
    </div>
<% end %>
<div class="pt-10">
    <div data-controller="chat-feedback" class ="flex flex-col max-w-xs landscape:max-w-3xl mx-auto">

        <!-- コントローラー名を chat-feedback と定義 -->
        <div class="chat chat-start w-full max-w-xl mx-auto px-4 py-5 flex flex-col gap-4"> 
            <!-- 各メッセージ要素に target を指定 -->
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><span class="loading loading-dots loading-sm"></span></div>

            <!-- ステキな箇所 -->
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["praise"] %></div>
            
            <!-- フィードバック総評 -->
            <div class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content flex flex-col gap-2">
                <!-- 太字で強調 -->
                <p class="font-bold text-lg opacity-75">📜総評 :</p>

                <p class="pl-8"><%= @game.score["image_analysis"] %></p>

                <!-- 薄い色で補足 -->
                <p class="flex justify-end text-xs text-base-content/25">※AIによる評価</p>
            </div>            

            <!-- スペルミス指摘 -->
            <% if @game.score["spelling_errors"].present? %>
                <div class="chat-bubble bg-base-100 text-base-content"> 
                    <p class="font-bold text-lg opacity-75">✒️スペルミス :</p>
                    <% @game.score["spelling_errors"].length.times do |n| %>
                                    
                        <div class="flex flex-row">
                            <p class="ml-8 flex items-center text-lg opacity-15"><%=n+1%>. </p>
                            <div class="ml-4 flex flex-col">
                                <div class="my-3 flex flex-col">
                                    <!-- 上段：間違い（薄め・打消し） -->
                                    <p class="pt-1 text-base font-mono opacity-50 border-b border-base-content/10">
                                    ✕ <%= @game.score["spelling_errors"][n]["error"] %>
                                    </p>
                                    
                                    <!-- 下段：正しいスペル（ここだけしっかり見せる） -->
                                    <p class="pt-1 text-base font-mono font-black text-success ">
                                    ◯ <%= @game.score["spelling_errors"][n]["correction"] %>
                                    </p>
                                </div>
                                <p class="<%= n+1 == @game.score["spelling_errors"].length ? '' : 'border-b-2 border-base-content/20' %> "></p>
                            </div>
                        </div>
                    <% end %>
                    <!-- 薄い色で補足 -->
                    <p class="flex justify-end mt-2 text-xs text-base-content/25">※最大5つまで表示</p>
                </div>
            <% end %>

            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["original_text"] %></div>
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["rewritten_text"] %></div>

            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["key_points"]["point"] %></div>
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["key_points"]["explanation"] %></div>

            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["bonus_phrase"]["phrase"] %></div>
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["bonus_phrase"]["meaning"] %></div>
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["bonus_phrase"]["example"] %></div>
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["bonus_phrase"]["example_translation"] %></div>




        <!-- サンプル -->
            <div class="chat-bubble flex flex-col gap-2">
                <!-- 段落1: 通常のテキスト -->
                <p>こちらは通常の文章です。全体の流れを説明しています。</p>
                
                <!-- 段落2: 太字で強調 -->
                <p class="font-bold text-lg">ここが一番重要なポイントです！</p>
                
                <!-- 段落3: 薄い色で補足 -->
                <p class="text-xs text-base-content/70">※注記：このスタイルは自由に変更できます。</p>
            </div>

            <div class="chat-bubble flex flex-col gap-3">
                <p>以下のコマンドを実行してください。</p>
                
                <!-- コード風の段落（背景とフォントを変更） -->
                <p class="bg-base-300 text-warning font-mono p-2 rounded text-sm">
                npm install daisyui
                </p>
                
                <p class="text-sm">インストールが完了したら、設定ファイルを編集します。</p>
            </div>

            <div class="chat-bubble flex flex-col">
                <!-- 上部：送信者（小さく右寄せ） -->
                <span class="text-xs text-primary-content/60 text-right mb-1">あなた</span>
                
                <!-- 中央：メインのメッセージ（太字） -->
                <p class="font-semibold">了解しました。10分後に行きます！</p>
            </div>

            <div class="chat-bubble bg-base-300 text-base-content p-3 flex flex-col gap-2">
                
                <!-- 上段：間違い（薄め・打消し） -->
                <p class="text-base font-mono opacity-50 pb-1 border-b border-base-content/10">
                ✕ beautifull
                </p>
                
                <!-- 下段：正しいスペル（ここだけしっかり見せる） -->
                <p class="text-base font-mono font-black text-success">
                ◯ beautiful
                </p>
                
            </div>


            <div class="chat-bubble bg-base-200 text-base-content flex flex-col gap-1">
                
                <!-- 上段：問題の指摘（単語のみにフォーカス） -->
                <p class="font-mono text-base-content/60">
                <span class="line-through text-error/80">recive</span> 
                <span class="mx-2 text-base-content/40">→</span> 
                <span class="font-bold text-success underline decoration-2">receive</span>
                </p>
                
                <!-- 下段：薄い文字で1行アドバイス -->
                <p class="text-xs opacity-70 mt-1 border-t border-base-content/10 pt-1">
                「c」の後ろは「ei」の順番になります。
                </p>
                
            </div>

            <div class="chat-bubble bg-base-200 text-base-content flex flex-col gap-1.5 p-3">
                
                <p class="text-sm opacity-70">スペルをチェックしましょう。</p>
                
                <!-- 誤り：打消し線と赤文字 -->
                <p class="font-mono text-error/90 line-through">✕ enviorment</p>
                
                <!-- 正解：太字と緑文字 -->
                <p class="font-mono text-success font-bold">◯ environment</p>
                
            </div>


        <!-- /サンプル -->


            <!-- テスト用の削除ボタン（クリックすると removeFirst アクションを実行） -->
            <button data-action="click->chat-feedback#removeFirst" class="btn btn-error btn-sm mt-4">
                一番上を削除
            </button>

        </div>
        <div class="flex justify-center gap-15 landscape:gap-25"> 
            <%=button_to "リトライ", root_path, method: :get, class: "btn btn-lg btn-neutral btn-lg h-12 rounded-2xl" %>
            <%=button_to "やめる", root_path, method: :get, class: "btn btn-lg btn-neutral btn-lg h-12 rounded-2xl" %>
        </div> 
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <!-- 空欄 -->
<% end %>