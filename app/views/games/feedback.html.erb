<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <div class="flex items-end gap-0">
        <p class="text-2xl font-bold">フィードバック</p>
    </div>
<% end %>

<div class="pt-10">
    <div class ="max-w-xs landscape:max-w-3xl mx-auto">
        <div class="w-full max-w-xl mx-auto px-4 py-5 flex flex-col gap-4">
            <div data-controller="auto-message" data-auto-message-url-value="<%= feedback_game_path(@game) %>">
                    <%= turbo_stream_from "chat_messages_container_for_job" %>
                    <div id="chat_messages_container">

                        <!-- タイプ中アニメーション -->
                        <div class="chat chat-start">
                            <div class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><span class="loading loading-dots loading-sm"></span></div>
                        </div>
                    </div>
                </div> 
            </div>
        </div>
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <!-- 空欄 -->
<% end %>