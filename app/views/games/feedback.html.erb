<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <div class="flex items-end gap-0">
        <p class="text-2xl font-bold">フィードバック</p>
    </div>
<% end %>
<div class="pt-10">
    <div data-controller="chat-feedback" class ="flex flex-col max-w-xs landscape:max-w-3xl mx-auto">

        <!-- コントローラー名を chat-feedback と定義 -->
        <div class="chat chat-start w-full max-w-xl mx-auto px-4 py-5 flex flex-col gap-4"> 
            <!-- 各メッセージ要素に target を指定 -->
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><span class="loading loading-dots loading-sm"></span></div>

            <!-- ステキな箇所 -->
            <div data-chat-feedback-target="message" class="chat-bubble whitespace-pre-wrap bg-base-100 text-base-content"><%= @game.score["praise"] %></div>
            
            <!-- フィードバック総評 -->
            <div class="chat-bubble bg-base-100 flex flex-col">
                <!-- 太字で強調 -->
                <p class="text-lg opacity-75">📄総評 :</p>
                <div class="ml-8">
                    <div class="border-l-2 border-base-content/20 flex flex-col gap-0.5 my-1">
                        <p class="pl-4"><%= @game.score["image_analysis"] %></p>
                    </div>
                </div>
            </div>            

            <!-- まとめ -->
            <div class="chat-bubble bg-base-100 flex flex-col">
                <p class="text-lg opacity-75">🎗️まとめ</p>
                <p class="ml-4 text-lg"><%= @game.score["key_points"]["point"] %></p>
                <div class="ml-8">
                    <div class="border-l-2 border-base-content/20 flex flex-col gap-0.5 my-1">
                        <p class="pl-4"><%= @game.score["key_points"]["explanation"] %></p>
                    </div>
                </div>
            </div>

            <!-- スペルミス指摘 -->
            <% if @game.score["spelling_errors"].present? %>
                <div class="chat-bubble bg-base-100 text-base-content"> 
                    <p class="text-lg opacity-75">✒️スペルミス :</p>
                    <% @game.score["spelling_errors"].length.times do |n| %>
                                    
                        <div class="flex flex-row">
                            <p class="ml-8 flex items-center text-lg opacity-15"><%=n+1%>. </p>
                            <div class="ml-4 flex flex-col">
                                <div class="my-3 flex flex-col">
                                    <!-- 上段：間違い -->
                                    <p class="pt-1 text-base font-mono opacity-50 border-b border-base-content/10">
                                    ✕ <%= @game.score["spelling_errors"][n]["error"] %>
                                    </p>
                                    
                                    <!-- 下段：正しいスペル -->
                                    <p class="pt-1 text-base font-mono font-black text-success ">
                                    ◯ <%= @game.score["spelling_errors"][n]["correction"] %>
                                    </p>
                                </div>
                                <p class="<%= n+1 == @game.score["spelling_errors"].length ? '' : 'border-b-2 border-base-content/20' %> "></p>
                            </div>
                        </div>
                    <% end %>
                    <!-- 薄い色で補足 -->
                    <p class="flex justify-end mt-2 text-xs text-base-content/25">※最大5つまで表示</p>
                </div>
            <% end %>


            <!-- 説明文比較 -->
            <div class="chat-bubble bg-base-100 text-base-content"> 
                <p class="text-lg opacity-75">🌷より自然な表現 :</p>           

                <div class="ml-4 flex flex-col">
                    <!-- 上段：原文 -->
                    <p class="flex justify-start mt-2 text-xs text-base-content/50">あなたの説明 :</p>

                    <p class="ml-8 pt-1 pb-2 text-base font-mono opacity-50 border-b border-base-content/10">
                        <%= @game.score["original_text"] %>
                    </p>
                    
                    <!-- 下段：修正後 -->
                    <p class="flex justify-start mt-2 text-xs text-base-content/50">提案 :</p>
                    <p class="ml-8 pt-1 text-base font-mono font-black text-success ">
                        <%= @game.score["rewritten_text"] %>
                    </p>
                </div>

            </div>

            <!-- 新フレーズ -->
            <div class="chat-bubble bg-base-100 flex flex-col">
                <p class="text-lg opacity-75">🎁更なる表現力アップへ</p>
                <div class="ml-4">
                    <p class="text-lg">「<%= @game.score["bonus_phrase"]["phrase"] %>」</p>
                    <p class="ml-4 mt-2 mb-2 text-sm tracking-wide"><%= @game.score["bonus_phrase"]["meaning"] %></p>

                    <p class="ml-4 border-b-2 border-base-content/10"></p>
                    
                    <p class="mt-2">・<%= @game.score["bonus_phrase"]["example"] %></p>
                </div>
                <div class="ml-8">
                    <div class="border-l-2 border-base-content/20 flex flex-col gap-0.5 my-1">


                        <!-- 翻訳は説明言語と学習言語が同じ場合、非表示にすること -->
                        <p class="pl-4"><%= @game.score["bonus_phrase"]["example_translation"] %></p>
                    </div>
                </div>
            </div>


            <!-- テスト用の削除ボタン（クリックすると removeFirst アクションを実行） -->
            <button data-action="click->chat-feedback#removeFirst" class="btn btn-error btn-sm mt-4">
                一番上を削除
            </button>

        </div>
        <div class="flex justify-center gap-15 landscape:gap-25"> 
            <%=button_to "リトライ", root_path, method: :get, class: "btn btn-lg btn-neutral btn-lg h-12 rounded-2xl" %>
            <%=button_to "やめる", root_path, method: :get, class: "btn btn-lg btn-neutral btn-lg h-12 rounded-2xl" %>
        </div> 
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <!-- 空欄 -->
<% end %>