<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <%= link_to "＜", root_path, class: "text-2xl font-bold" %>
<% end %>

<div class="hero items-start">
    <div class="hero-content text-center">
        <div class="max-w-md grid place-items-center gap-3">
            <p class="text-4xl">お題</p>
            <p class="text-base">このイメージを言葉で伝えてください。</p>
            <img
            id="gacha-image"
            src="<%= @game.theme_image_url %>"
            alt="ランダムイメージ"
            class="rounded-4xl">

            <%= form_with model: @game do |f| %>
                <%= f.hidden_field :theme_image_url %><br>
                <%= f.submit "つぎへ", class: "flex btn btn-lg btn-primary w-70 h-12 rounded-2xl" %>
            <% end %>
        </div>
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <p></p>
<% end %>