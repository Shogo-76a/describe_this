<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <%= link_to "＜", new_game_path, class: "text-2xl font-bold" %>
<% end %>

<div class="m-4 flex flex-col landscape:m-0 landscape:hero">
    <div data-collapsible-image-target="wrapperGlobal"
        data-controller="collapsible-image"
        class="relative w-full aspect-[800/600] overflow-hidden 
            landscape:hero-content landscape:flex landscape:flex-row landscape:gap-4">

        <div data-collapsible-image-target="wrapperA"
            data-action="click->collapsible-image#toggle"
            class="absolute top-0 left-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                landscape:h-auto">

            <div class="w-full h-full landscape:h-auto">
                <img
                    id="gacha-image"
                    src="<%= @game.theme_image_url %>"
                    alt="お題イメージ"
                    class="w-full h-full landscape:h-auto object-cover object-left rounded-4xl">
            </div>
        </div>

        <div data-collapsible-image-target="wrapperB"
            data-action="click->collapsible-image#toggle"
            class="absolute top-0 right-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                landscape:h-auto">
            <div class="w-full h-full landscape:h-auto">
                <% if @game.generated_image.attatched? %>
                    <img
                    id="gacha-image"
                    src="<%= @game.generated_image %>"
                    alt="生成イメージ"
                    class="w-full h-full landscape:h-auto object-cover object-right rounded-4xl">
                <% else %>
                    <div class="w-full h-full landscape:h-auto object-cover object-right aspect-[800/600] bg-base-100 rounded-4xl"></div>
                <% end %>
            </div>
        </div>
    </div>
    <div class="flex justify-center m-5">
        <%=button_to "採点", '#', method: :get, class: "btn btn-lg btn-primary text-primary-content w-70 h-12 rounded-2xl" %>
    </div>
</div>

<!-- チャット欄 -->
<div class="bg-neutral">
    <div class="w-full max-w-xl mx-auto px-4 py-8 flex flex-col gap-4">
    
    <div class="chat chat-start">
        <div class="chat-image avatar">
        <div class="w-10 rounded-full bg-neutral text-neutral-content flex items-center justify-center">
            <span>AI</span>
        </div>
        </div>
        <div class="chat-header text-xs opacity-50 mb-1">
        サポートAI <time class="text-xs opacity-50">12:45</time>
        </div>
        <div class="chat-bubble bg-neutral text-neutral-content">
        こんにちは！何かお手伝いできることはありますか？
        </div>
    </div>

    <div class="chat chat-end">
        <div class="chat-header text-xs opacity-50 mb-1">
        あなた <time class="text-xs opacity-50">12:46</time>
        </div>
        <div class="chat-bubble chat-bubble-primary">
        TailwindとdaisyUIを使ってチャット画面を作りたいです。
        </div>
        <div class="chat-footer opacity-50 text-xs mt-1">
        既読
        </div>
    </div>

    <div class="chat chat-start">
        <div class="chat-image avatar">
        <div class="w-10 rounded-full bg-neutral text-neutral-content flex items-center justify-center">
            <span>AI</span>
        </div>
        </div>
        <div class="chat-header text-xs opacity-50 mb-1">
        サポートAI <time class="text-xs opacity-50">12:46</time>
        </div>
        <div class="chat-bubble bg-neutral text-neutral-content">
        素晴らしいですね！このコンポーネントを使えば、テーマ切り替えにもバッチリ対応できますよ。
        </div>
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <div class="fixed bottom-0 left-0 right-0 bg-base-100 py-4 px-4 z-10">
        <div class="max-w-2xl mx-auto w-full">

            <%= form_with model: @game, local: false, class: "flex gap-2 items-center",
             data: { controller: "chat-form", action: "turbo:submit-end->chat-form#clear" } do |f| %>
            
                <!-- テキスト入力欄 -->
                <%= f.text_field :description, 
                        placeholder: "メッセージを入力...", 
                        class: "input input-bordered flex-1 bg-base-100 text-base-content focus:outline-primary",
                        autocomplete: "off" %>
                <!-- 送信ボタン -->
                <%= f.button class: "btn btn-primary" do %>
                    <span>送信</span>
                <% end %>
            <% end %>
        </div>
    </div>
<% end %>