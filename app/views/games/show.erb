<!-- ヘッダーの内容変更 -->
<% provide(:header_content) do %>
    <%= link_to "＜", new_game_path, class: "text-2xl font-bold" %>
<% end %>

<div class="landscape:hero">
    <div data-collapsible-image-target="wrapperGlobal"
        data-controller="collapsible-image"
        class="relative w-full aspect-[800/600] overflow-hidden 
            landscape:hero-content landscape:flex landscape:flex-row landscape:gap-4">

        <div data-collapsible-image-target="wrapperA"
            data-action="click->collapsible-image#activateA"
            class="absolute top-0 left-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                landscape:h-auto">

            <div class="w-full h-full landscape:h-auto">
                <img
                    id="gacha-image"
                    src="<%= @game.theme_image_url %>"
                    alt="お題イメージ"
                    class="w-full h-full landscape:h-auto object-cover object-left rounded-4xl">
            </div>
        </div>

        <div data-collapsible-image-target="wrapperB"
            data-action="click->collapsible-image#activateB"
            class="absolute top-0 right-0 h-full landscape:h-auto w-1/2 transition-all duration-500 ease-in-out
                landscape:h-auto">
            <div class="w-full h-full landscape:h-auto">
                <% if @game.generated_image.attatched? %>
                    <img
                    id="gacha-image"
                    src="<%= @game.generated_image %>"
                    alt="生成イメージ"
                    class="w-full h-full landscape:h-auto object-cover object-right rounded-4xl">
                <% else %>
                    <div class="w-full h-full landscape:h-auto object-cover object-right aspect-[800/600] bg-gray-500 rounded-4xl"></div>
                <% end %>
            </div>
        </div>
    </div>
</div>


<!-- フッターの内容変更 -->
<% provide(:footer_content) do %>
    <p></p>
<% end %>