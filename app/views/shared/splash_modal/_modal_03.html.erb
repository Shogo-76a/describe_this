<%= turbo_frame_tag "tutorial_step" do %>
  <div class="py-4">
    <div class="text-5xl mb-4">🎉</div>
    <h3 class="text-xl font-bold">準備完了です！</h3>
    <p class="py-4 text-sm text-base-content/70">さあ、新しくなったアプリを存分に体験してください。</p>
    
    <ul class="steps steps-horizontal w-full my-4 text-xs">
      <li class="step step-primary">設定</li>
      <li class="step step-primary">探す</li>
      <li class="step step-primary">楽しむ</li>
    </ul>

    <div class="modal-action">
      <form method="dialog" class="w-full">
        <button class="btn btn-success w-full">アプリを始める</button>
      </form>
    </div>
  </div>
<% end %>