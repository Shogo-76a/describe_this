    <div class="text-5xl mb-4">🚀</div>
    <h3 class="text-xl font-bold">ステップ 1: アカウントの設定</h3>
    <p class="py-4 text-sm text-base-content/70">まずはプロファイルを入力して、あなた好みにカスタマイズしましょう。</p>
    
    <div class="flex items-center justify-center gap-2">
      <span class="h-3 w-3 rounded-full bg-primary"></span>
      <span class="h-3 w-3 rounded-full bg-base-300"></span>
      <span class="h-3 w-3 rounded-full bg-base-300"></span>
    </div>

    <div class="modal-action justify-center">
      <%= link_to "つぎへ", tutorial_step_path(step: 2), class: "btn btn-primary w-full" %>
    </div>
  </div>
<% end %>