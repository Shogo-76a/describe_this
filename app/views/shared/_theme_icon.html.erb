<!--
  テーマアイコンのPartial
  呼び出し元から `theme_name` 変数を受け取り、data-theme属性を付与します。
-->
<span class="flex items-center" data-theme="<%= theme_name %>">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 rounded-md bg-base-100 p-1 shadow-sm border border-base-content/10" viewBox="0 0 24 24">
    <circle cx="7" cy="7" r="3.5" class="fill-base-content" />
    <circle cx="17" cy="7" r="3.5" class="fill-primary" />
    <circle cx="7" cy="17" r="3.5" class="fill-secondary" />
    <circle cx="17" cy="17" r="3.5" class="fill-accent" />
  </svg>
</span>