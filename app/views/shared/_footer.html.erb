<footer class="footer footer-horizontal footer-center flex items-center justify-center bg-base-100 text-neutral-content h-20 pb-8 m-0">
  <div>
    <% if content_for?(:footer_content) %>
      <%= yield :footer_content %>
    <% else %>
      <div data-controller="footer-navigation" class="btm-nav flex gap-10">
        <%= link_to root_path, data: { footer_navigation_target: "link" } do %>
            <span class="nav-label w-20 inline-grid place-items-center text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 mx-auto">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
                <span class="text-xs">ホーム</span>
            </span>
        <% end %>
        <%= link_to '#', data: { footer_navigation_target: "link" } do %>
            <span class="nav-label w-20 inline-grid place-items-center text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 mx-auto">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
                <span class="text-xs">プレイ履歴</span>
            </span>
        <% end %>
        <%= link_to user_path(9999), data: { footer_navigation_target: "link" } do %> <!-- MVP用の仮プロフィールページ -->
            <span class="nav-label w-20 inline-grid place-items-center text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 mx-auto">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
                <span class="text-xs">プロフィール</span>
            </span>
        <% end %>
      </div>
    <% end %>
  </div>
</footer>