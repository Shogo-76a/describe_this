<header class="navbar bg-base-100">
    <!-- ページごとに書き換わるエリア -->
    <% if content_for?(:header_content) %>
        <%= yield :header_content %>
    <% else %>
        <!-- どのページでも設定されていない場合のデフォルト表示 -->
        <%= link_to image_tag("DT_logo.png", alt: "logo", class: "w-10 h-auto"), root_path%>
    <% end %>
</header>