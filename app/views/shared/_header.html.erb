<header class="navbar bg-base-100 p-2">
    <!-- ページごとに書き換わるエリア -->
    <% if content_for?(:header_content) %>
        <%= yield :header_content %>
    <% else %>
        <!-- どのページでも設定されていない場合のデフォルト表示 -->

        <!-- ロゴ -->
        <div 
                class="bg-primary w-11 h-11" 
                style="
                    -webkit-mask-image: url('<%= asset_path("DT_logo.png") %>');
                    mask-image: url('<%= asset_path("DT_logo.png") %>');
                    -webkit-mask-size: contain;
                    mask-size: contain;
                    -webkit-mask-repeat: no-repeat;
                    mask-repeat: no-repeat;
                    -webkit-mask-position: center;
                    mask-position: center;
                "
                ></div>

        <!-- data-controller="theme-select" を追加します -->
        <select 
        data-controller="theme-select" 
        data-action="change->theme-select#change"
        class="select select-bordered w-full max-w-xs"
        >
            <option value="light">Default (Light)</option>
            <option value="dark">Dark</option>
            <option value="cupcake">Cupcake</option>
            <option value="bumblebee">Bumblebee</option>
        </select>
    <% end %>
</header>